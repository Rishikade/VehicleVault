@{
    var v1 = ViewBag.V1;
    var v2 = ViewBag.V2;

    int score1 = 0;
    int score2 = 0;

    if (v1 != null && v2 != null)
    {
        // Price (LOW better)
        if (v1.Price < v2.Price) score1++;
        else if (v2.Price < v1.Price) score2++;

        // Mileage (HIGH better)
        if (v1.Mileage > v2.Mileage) score1++;
        else if (v2.Mileage > v1.Mileage) score2++;

        // Engine (HIGH better - extract number)
        int e1 = int.Parse(v1.Engine.Replace("cc", ""));
        int e2 = int.Parse(v2.Engine.Replace("cc", ""));

        if (e1 > e2) score1++;
        else if (e2 > e1) score2++;
    }
}

<h2 style="text-align:center; color:white;">⚔️ Comparison Result</h2>

@if (v1 != null && v2 != null)
{
    <div style="display:flex; justify-content:center; gap:30px; margin-top:30px;">

        <!-- Vehicle 1 -->
        <div style="width:250px; padding:20px; border-radius:12px;
            background:@(score1 > score2 ? "#14532d" : "#1e293b");
            color:white; text-align:center; box-shadow:0 0 15px rgba(0,0,0,0.5);">

            <h3>@v1.Name</h3>
            <p>💰 ₹@v1.Price</p>
            <p>⛽ @v1.Mileage km/l</p>
            <p>⚙️ @v1.Engine</p>
            <p>🛢️ @v1.Fuel</p>
            <p>🛡️ @v1.Safety</p>

            @if (score1 > score2)
            {
                <p style="color:#22c55e; font-weight:bold;">🏆 Winner</p>
            }
        </div>

        <!-- Vehicle 2 -->
        <div style="width:250px; padding:20px; border-radius:12px;
            background:@(score2 > score1 ? "#14532d" : "#1e293b");
            color:white; text-align:center; box-shadow:0 0 15px rgba(0,0,0,0.5);">

            <h3>@v2.Name</h3>
            <p>💰 ₹@v2.Price</p>
            <p>⛽ @v2.Mileage km/l</p>
            <p>⚙️ @v2.Engine</p>
            <p>🛢️ @v2.Fuel</p>
            <p>🛡️ @v2.Safety</p>

            @if (score2 > score1)
            {
                <p style="color:#22c55e; font-weight:bold;">🏆 Winner</p>
            }
        </div>

    </div>

    <!-- RESULT TEXT -->
    <div style="text-align:center; margin-top:30px; color:white;">

        @if (score1 > score2)
        {
            <h3 style="color:#22c55e;">🔥 @v1.Name is Best Overall</h3>
        }
        else if (score2 > score1)
        {
            <h3 style="color:#22c55e;">🔥 @v2.Name is Best Overall</h3>
        }
        else
        {
            <h3 style="color:#facc15;">⚖️ Both are Equal</h3>
        }

    </div>
}
else
{
    <h3 style="text-align:center; color:white;">Select both vehicles 😅</h3>
}