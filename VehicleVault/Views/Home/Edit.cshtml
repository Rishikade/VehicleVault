@model VehicleVault.Models.Vehicle

<h2>Edit Vehicle</h2>

<form method="post">
    <input type="hidden" name="VehicleID" value="@Model.VehicleID" />

    <input type="text" name="VehicleName" value="@Model.VehicleName" /><br />
    <input type="number" name="Price" value="@Model.Price" /><br />
    <input type="number" name="Mileage" value="@Model.Mileage" /><br />
    <input type="text" name="Engine" value="@Model.Engine" /><br />
    <input type="text" name="FuelType" value="@Model.FuelType" /><br />
    <input type="text" name="SafetyFeatures" value="@Model.SafetyFeatures" /><br />

    <button type="submit">Update</button>
</form>