@model List<VehicleVault.Models.Vehicle>

<h2 style="text-align:center;">🚗 Vehicle Vault</h2>

<div style="text-align:center; margin-bottom:20px;">
    <a href="/Home/Create">➕ Add Vehicle</a>
</div>

<form method="get" style="margin-bottom:20px; display:flex; gap:10px;">

    <input type="text" name="search" value="@Context.Request.Query["search"]"
           placeholder="Search by name..."
           style="padding:8px; border-radius:6px; border:none;" />

    <select name="fuel" style="padding:8px; border-radius:6px;">
        <option value="">All Fuel</option>
        <option value="Petrol">Petrol</option>
        <option value="Electric">Electric</option>
    </select>

    <button type="submit" style="
        padding:8px 15px;
        background:#22c55e;
        border:none;
        border-radius:6px;
        color:black;">
        Search
    </button>

</form>

<div style="display:flex; gap:20px; justify-content:center; flex-wrap:wrap;">

    @foreach (var v in Model)
    {
        <div style="width:250px; padding:15px; border-radius:10px; background:#1e293b; color:white; text-align:center; box-shadow:0 0 10px rgba(0,0,0,0.5);">

            <h3>@v.Name</h3>
            <p>💰 ₹@v.Price</p>
            <p>⛽ @v.Mileage km/l</p>
            <p>⚙️ @v.Engine</p>
            <p>🛢️ @v.Fuel</p>
            <p>🛡️ @v.Safety</p>

            <a href="/Home/Edit/@v.Id">Edit</a> |
            <a href="/Home/Delete/@v.Id">Delete</a>
        </div>
    }

</div>