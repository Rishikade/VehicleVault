@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Register - VehicleVault</title>

    <style>
        body {
            margin: 0;
            height: 100vh;
            font-family: 'Segoe UI';
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(-45deg, #020617, #0f172a, #1e293b, #020617);
            background-size: 400% 400%;
            animation: gradientBG 10s ease infinite;
        }

        @@keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .box {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            padding: 40px;
            border-radius: 20px;
            width: 340px;
            text-align: center;
            box-shadow: 0 0 40px rgba(0,0,0,0.6);
            animation: fadeIn 0.8s ease;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h2 {
            color: white;
            margin-bottom: 25px;
        }

        .input-group {
            position: relative;
            margin: 18px 0;
        }

        input {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            border: none;
            outline: none;
            background: #1e293b;
            color: white;
        }

        label {
            position: absolute;
            left: 12px;
            top: 12px;
            color: #94a3b8;
            font-size: 14px;
            pointer-events: none;
            transition: 0.3s;
        }

        input:focus + label,
        input:valid + label {
            top: -8px;
            font-size: 12px;
            color: #22c55e;
        }

        .password-wrapper {
            position: relative;
        }

        .eye {
            position: absolute;
            right: 10px;
            top: 12px;
            cursor: pointer;
            color: #94a3b8;
        }

        button {
            width: 100%;
            padding: 12px;
            margin-top: 20px;
            background: #22c55e;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: #16a34a;
            transform: scale(1.05);
            box-shadow: 0 0 15px #22c55e;
        }

        .link {
            margin-top: 15px;
            display: block;
            color: #38bdf8;
            text-decoration: none;
        }

        .link:hover {
            text-decoration: underline;
        }

        .error {
            color: red;
            margin-top: 10px;
        }
    </style>
</head>

<body>

<div class="box">
    <h2>🚗 Create Account</h2>

    <form method="post">

        <div class="input-group">
            <input type="text" name="Username" required />
            <label>Username</label>
        </div>

        <div class="input-group password-wrapper">
            <input type="password" id="pass1" name="Password" required />
            <label>Password</label>
            <span class="eye" onclick="togglePass('pass1')">👁️</span>
        </div>

        <div class="input-group password-wrapper">
            <input type="password" id="pass2" name="ConfirmPassword" required />
            <label>Confirm Password</label>
            <span class="eye" onclick="togglePass('pass2')">👁️</span>
        </div>

        <button type="submit">Register</button>

    </form>

    <a class="link" href="/Account/Login">Already have an account? Login</a>

    @if (ViewBag.Error != null)
    {
        <div class="error">@ViewBag.Error</div>
    }

</div>

<script>
function togglePass(id) {
    var p = document.getElementById(id);
    p.type = (p.type === "password") ? "text" : "password";
}
</script>

</body>
</html>