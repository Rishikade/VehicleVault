<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>VehicleVault</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
            body {
                background: linear-gradient(135deg, #0f172a, #1e293b);
                color: white;
                font-family: 'Segoe UI';
            }

            .navbar {
                background: rgba(0,0,0,0.6);
                backdrop-filter: blur(10px);
            }

            .card {
                background: #1e293b;
                border-radius: 15px;
                transition: 0.3s;
                border: none;
            }

            .card:hover {
                transform: scale(1.05);
                box-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
            }

            .btn-gold {
                background: gold;
                color: black;
                border-radius: 10px;
            }

            .btn-gold:hover {
                background: #ffd700;
            }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg px-4">
        <a class="navbar-brand text-white fw-bold">🚗 VehicleVault</a>

        <div class="ms-auto">
            <a href="/Home/Index" class="btn btn-outline-light me-2">Home</a>
            <a href="/Home/Compare" class="btn btn-gold">Compare</a>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <style>
            body {
                background-color: #0f172a;
                color: white;
            }

            .card {
                background-color: #1e293b;
                color: white;
            }

            .btn {
                border-radius: 10px;
            }
    </style>

</body>
</html>